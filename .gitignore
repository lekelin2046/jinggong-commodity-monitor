# Excel 共享表（精工业务数据，不入 git）
*.xlsx
*.xls
*.bak.*
.~*.xlsx

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# macOS
.DS_Store
._*

# 临时文件
*.tmp
*.swp
*~

# 日志
*.log
logs/

# 数据/输出目录（看板 HTML 需入 git 供 GitHub Pages 部署）
data/
output/*
!output/看板.html

# 个人备份
*.bak
*~

# 内部业务文档（可能含真实价格数据，不传公网）
*.pdf
核查报告*.md

# 每日抓取的当日数据归档（含 ccmn 真实价格，不传公网）
长城有色日价格查询/

# 每日抓取截图（含亚洲金属网/SMM 登录态截图，严禁入 git）
screenshots/

# 凭据文件（含 SMM / 亚洲金属网账号密码，严禁入 git）
.env
.env.local
.env.*.local
secrets.json
credentials.json

# 浏览器调试缓存（可能含登录态/cookie，严禁入 git）
.chrome-debug-profile/

# 导出的第三方站点 cookie（含卓创会员会话凭证，严禁入 git）
cookies/
.workbuddy/
.codebuddy/
.trae-html-share-packages/
dist/

# 临时分析产物
jinggong-eval-*/
项目评价报告*.html
