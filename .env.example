# 精工大宗商品监控系统 - 凭据配置
#
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填入真实账号密码
#   3. .env 已在 .gitignore 中，不会提交到 git
#
# 凭据来源：长城保理精工板块 SMM / 亚洲金属网付费账号
# 轮换密码后请同步更新 .env

# SMM 上海有色网（ADC12/A380/AlSi9Cu3/A356/闻喜镁/AM60B/AZ91D 共 7 品种）
SMM_ACCOUNT=
SMM_PASSWORD=

# 亚洲金属网（闻喜镁锭，图片渲染需 OCR 兜底）
ASIANMETAL_ACCOUNT=
ASIANMETAL_PASSWORD=

# OCR.space API key（亚洲金属网图片价格 OCR 兜底用，可选）
# 注册地址：https://ocr.space/ocrapi
# 留空则使用本地 OCR（PaddleOCR）或跳过图片价格
OCR_SPACE_APIKEY=
